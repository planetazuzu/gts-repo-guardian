{
  "name": "gts-repo-guardian",
  "version": "1.0.0",
  "description": "MCP para gestión y revisión automática de repos GitHub - GTS SOFTWARE",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/templates dist/",
    "start": "node dist/index.js",
